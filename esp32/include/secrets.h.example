#pragma once
// ─────────────────────────────────────────────────────────────────────────────
// secrets.h.example — copy to secrets.h and fill in your values.
// secrets.h is gitignored and never committed.
// ─────────────────────────────────────────────────────────────────────────────

// Home WiFi — your main network (owner + Home Assistant)
#define WIFI_SSID  "YOUR_SSID"
#define WIFI_PASS  "YOUR_PASSWORD"

// Full owner key — read + write everything. Must match your PWA / HA settings.
#define API_KEY    "change-me-to-something-secret"

// Unique stable identifier for this controller — used by HA as device unique_id
// Use a short slug: e.g. "backyard", "front-yard", "sycamore"
#define CONTROLLER_ID  "change-me-to-controller-id"

// Guest AP — hotspot the ESP32 broadcasts for landscaper QR access.
// Runs simultaneously with home WiFi (AP+STA mode). AP IP = 192.168.4.1.
// No internet, fully isolated from your LAN.
#define AP_SSID    "Sprinkler"
#define AP_PASS    "change-me-ap-password"

// Guest key — run-only (status, config read, manual ON/OFF; no config changes).
// Encode in the landscaper QR URL: http://192.168.4.1/?key=<GUEST_KEY>
#define GUEST_KEY  "change-me-guest-key"
